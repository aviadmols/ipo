  <div class="plan_banner">
<div class="row">
        <div class=" col-md-12 col-sm-12 col-xs-12 banner_image"><a href="<?php echo get_permalink(); ?>"><img src="<?php echo $bannerimage['url']; ?>" alt="<?php echo $bannerimage['alt']; ?>" /></a></div>
